<style>
  .search-btn {
    background-color: #fe424d;
    color: white;
    border-radius: 25px;
    padding: 0 1rem;
  }
  .search-btn:hover {
    background-color: #fe424d;
    color: white;
  }
  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    font-size: 1rem;
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid px-4">

    <!-- Brand -->
    <a class="navbar-brand d-flex align-items-center gap-2" href="/listings">
      <i class="fa-solid fa-house"></i>
      <span class="fw-bold">ChillGhar</span>
    </a>

    <!-- Hamburger -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <!-- Left Links -->
      <div class="navbar-nav me-3">
        <a class="nav-link" href="/listings">Explore</a>
        <% if(currUser) { %>
          <a class="nav-link" href="/listings/new">New Listings</a>
        <% } %>
      </div>

      <!-- Center Search -->
      <form action="/listings/search" method="GET" class="d-flex mx-auto" role="search">
        <input
          class="form-control me-2 search-inp"
          type="search"
          name="title"
          placeholder="<%= currUser ? 'Search destinations' : 'Login to search' %>"
          aria-label="Search"
          <%= currUser ? '' : 'disabled' %>
        />
        <button class="btn search-btn" type="submit" <%= currUser ? '' : 'disabled' %>>Search</button>
      </form>

      <!-- Right Links -->
      <div class="navbar-nav ms-3 align-items-md-center">
        <% if(currUser) { %>
          <a class="nav-link" href="/listings/mylistings"><b>My Listings</b></a>
          <a class="nav-link" href="/logout"><b>Log Out</b></a>
        <% } else { %>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Log In</b></a>
        <% } %>
      </div>

    </div>
  </div>
</nav>