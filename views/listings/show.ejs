<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    
    <!-- Listing Title -->
    <div class="col-md-8 text-center mb-3">
      <h2 class="fw-bold"><%= listing.title %></h2>
    </div>

    <!-- Listing Card -->
    <div class="col-md-8">
      <div class="card shadow-sm show-card mb-4 listing-card ">
        <img
  src="<%= listing.image.url %>"
  class="card-img-top show-img"
  alt="listing_image"
/>  
        <div class="card-body">
          <p class="card-text">
            <strong>Owned by:</strong><%= listing.owner ? listing.owner.username : "Unknown User" %>
          </p>
          <p class="card-text">
            <%= listing.description %>
          </p>
          <p class="mb-1"><strong>Price:</strong> ₹<%= listing.price.toLocaleString("en-IN") %></p>
          <p class="mb-1"><strong>Location:</strong> <%= listing.location %></p>
          <p><strong>Country:</strong> <%= listing.country %></p>
        </div>
      </div>
    </div>

    <!-- Buttons -->
     <% if( currUser && listing.owner && currUser._id.equals(listing.owner._id)){ %>
    <div class="col-md-8 d-flex justify-content-between mb-4">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning px-4">Edit</a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-danger px-4">Delete</button>
      </form>
    </div>
    <%} %>

    <!-- Review Form -->
     
    <div class="col-md-8 mb-5">
      <% if(currUser) {%>
      <h4 class="text-center mb-4">Leave a Review</h4>
      
      <form action="/listings/<%= listing._id %>/reviews" method="POST" class="p-4 border rounded shadow-sm bg-light needs-validation" novalidate>
        
        <!-- Rating -->
         <label for="rating" class="form-label fw-bold">Rating</label>
        <div class="mb-3">
  <fieldset class="starability-slot">
    <input
      type="radio"
      id="no-rate"
      class="input-no-rate"
      name="review[rating]"
      value="0"
      checked
      aria-label="No rating."
    />

    <input type="radio" id="rate1" name="review[rating]" value="1" />
    <label for="rate1" title="Terrible">1 star</label>

    <input type="radio" id="rate2" name="review[rating]" value="2" />
    <label for="rate2" title="Not good">2 stars</label>

    <input type="radio" id="rate3" name="review[rating]" value="3" />
    <label for="rate3" title="Average">3 stars</label>

    <input type="radio" id="rate4" name="review[rating]" value="4" />
    <label for="rate4" title="Very good">4 stars</label>

    <input type="radio" id="rate5" name="review[rating]" value="5" />
    <label for="rate5" title="Amazing">5 stars</label>
  </fieldset>
</div>




        
        <!-- Comment -->
        <div class="mb-3">
          <label for="comment" class="form-label fw-bold "  >Your Comment</label>
          <textarea 
            name="review[comment]" 
            id="comment" 
            required
            class="form-control" 
            rows="4" 
            placeholder="Write your review here..."
          ></textarea>
          <div class="invalid-feedback">Add some comments for review</div>
        </div>
        
        <!-- Submit Button -->
        <div class="text-center">
          <button type="submit" class="btn btn-primary px-5">Submit Review</button>
        </div>
        <% } %>
      </form>
    </div>
    
    

<h4 class="mt-5 mb-3 text-center">All Reviews</h4>
<div class="row g-3 col-md-8 mx-auto">

  <% for(let review of listing.reviews) { %>
    <div class="col-md-6">
      <div class="card shadow-sm review-card h-100">
        <div class="card-body p-3">
          <!-- Reviewer Name -->
          <h6 class="card-subtitle mb-2 text-primary"><%= review.author.username %></h6>
          <!-- Rating -->
          <p class="starability-result" data-rating="<%= review.rating %>">
    Rated: <%= review.rating %>
  </p>
          <!-- Comment -->
          <p class="card-text"><%= review.comment %></p>
        </div>
        
 <form method="POST"  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"  class="p-3">
  <button class="btn btn-sm btn-dark">DELETE</button>
</form>
      </div>
    </div>
  <% } %>

</div>



  </div>
</div>
