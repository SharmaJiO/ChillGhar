<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
  <h1 class="col-8 offset-3">login on ChillGhar</h1>
  <div class="col-8 offset-3">
    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username">Username</label>
        <input
          type="text"
          name="username"
          id="username"
          required
          class="form-control"
        />
      </div>

      <div>
        <label for="identity">Login as</label>
        <select name="identity" id="identity" class="form-select" required>
          <option value="guest">Guest</option>
          <option value="host">Host</option>
        </select>
      </div>

      <div class="mb-3">
        <label for="password">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          required
          class="form-control"
        />
      </div>

      <button class="btn btn-success">Login</button>
      <p class="mt-3">Don't have an account? <a href="/signup">Sign Up here</a></p>
    </form>
  </div>
</div>
